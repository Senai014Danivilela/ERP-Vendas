    { Private declarations }
   // procedure SelecionarAcoesAcessoPorUsuario;
    procedure SelecionarAcoesAcessoPorPerfil;
    public
    { Public declarations }
  end;

var
  frmUsuarioVsAcoes: TfrmUsuarioVsAcoes;

implementation

{$R *.dfm}


procedure TfrmUsuarioVsAcoes.btnFecharClick(Sender: TObject);
begin
  Close;
end;

procedure TfrmUsuarioVsAcoes.FDQUsuarioAfterScroll(DataSet: TDataSet);
begin
  SelecionarAcoesAcessoPorPerfil;
end;

procedure TfrmUsuarioVsAcoes.SelecionarAcoesAcessoPorPerfil;
begin
  FDQAcoes.Close;
  FDQAcoes.ParamByName('perfilId').AsInteger :=
  FDQUsuario.FieldByName('perfilId').AsInteger;
  FDQAcoes.Open;
end;



procedure TfrmUsuarioVsAcoes.FormShow(Sender: TObject);
begin
  FDQUsuario.Open;
  SelecionarAcoesAcessoPorPerfil;
end;

procedure TfrmUsuarioVsAcoes.grdAcoesDblClick(Sender: TObject);
var
  Qry: TFDQuery;
  bm: TBookmark;
  ativo: Boolean;
begin
  bm := FDQAcoes.GetBookmark;

  ativo := not FDQAcoes.FieldByName('ativo').AsBoolean;

  Qry := TFDQuery.Create(nil);
  try
    Qry.Connection := dtmPrincipal.dtmPrincipalDB;

    // ?? verifica se já existe
    Qry.SQL.Text :=
      'SELECT COUNT(*) AS Qtde FROM PERFILACAO '+
      'WHERE perfilId = :perfilId AND AcaoAcessoId = :acaoId';

    Qry.ParamByName('perfilId').AsInteger :=
      FDQUsuario.FieldByName('perfilId').AsInteger;

    Qry.ParamByName('acaoId').AsInteger :=
      FDQAcoes.FieldByName('AcaoAcessoId').AsInteger;

    Qry.Open;

    if Qry.FieldByName('Qtde').AsInteger = 0 then
    begin
      Qry.Close;
      Qry.SQL.Text :=
        'INSERT INTO PERFILACAO (perfilId, AcaoAcessoId, ativo) '+
        'VALUES (:perfilId, :acaoId, :ativo)';
    end
    else
    begin
      Qry.Close;
      Qry.SQL.Text :=
        'UPDATE PERFILACAO SET ativo = :ativo '+
        'WHERE perfilId = :perfilId AND AcaoAcessoId = :acaoId';
    end;

    Qry.ParamByName('perfilId').AsInteger :=
      FDQUsuario.FieldByName('perfilId').AsInteger;

    Qry.ParamByName('acaoId').AsInteger :=
      FDQAcoes.FieldByName('AcaoAcessoId').AsInteger;

    Qry.ParamByName('ativo').AsBoolean := ativo;

    dtmPrincipal.dtmPrincipalDB.StartTransaction;
    try
      Qry.ExecSQL;
      dtmPrincipal.dtmPrincipalDB.Commit;
    except
      dtmPrincipal.dtmPrincipalDB.Rollback;
    end;

  finally
    Qry.Free;
    SelecionarAcoesAcessoPorPerfil;
    FDQAcoes.GotoBookmark(bm);
  end;
end;


procedure TfrmUsuarioVsAcoes.grdAcoesDrawColumnCell(Sender: TObject;
  const Rect: TRect; DataCol: Integer; Column: TColumn; State: TGridDrawState);
begin
  If not FDQAcoes.FieldByName('ativo').AsBoolean  then
  begin
    TDBGrid(Sender).Canvas.Font.Color:= clWhite;
    TDBGrid(Sender).Canvas.Brush.Color:=clRed
  end;
  TDBGrid(Sender).DefaultDrawDataCell(Rect, TDBGrid(Sender).columns[datacol].field, State);
end;

