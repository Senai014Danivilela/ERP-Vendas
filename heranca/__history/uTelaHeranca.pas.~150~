 {$REGION 'SALVA POSIÇÂO NA GRID'}
procedure TForm1.SalvarColunas(aGrid: TDBGrid);
var INI: TIniFile; i: Integer;
begin
  INI := TIniFile.Create(ChangeFileExt(Application.ExeName, '.ini'));
  try
    for i := 0 to aGrid.Columns.Count-1 do
    begin
      // Salva largura e posição de cada coluna usando seção "Form_Grid"
      INI.WriteInteger(Self.Name+'_'+aGrid.Name, 'col_'+IntToStr(i)+'_larg', aGrid.Columns[i].Width);
      INI.WriteInteger(Self.Name+'_'+aGrid.Name, 'col_'+IntToStr(i)+'_pos',  aGrid.Columns[i].Index);
    end;
  finally
    FreeAndNil(INI); // sempre libera o arquivo INI
  end;
end;
  {$endregion}

{$REGION 'CARREGA  POSIÇÂO NA GRID  '}
procedure TForm1.CarregarColunas(aGrid: TDBGrid);
var INI: TIniFile; i: Integer;
begin
  INI := TIniFile.Create(ChangeFileExt(Application.ExeName, '.ini'));
  try
    for i := 0 to aGrid.Columns.Count-1 do
    begin
      // Carrega largura e posição — usa valor atual como padrão se não existir
      aGrid.Columns[i].Width := INI.ReadInteger(Self.Name+'_'+aGrid.Name, 'col_'+IntToStr(i)+'_larg', aGrid.Columns[i].Width);
      aGrid.Columns[i].Index := INI.ReadInteger(Self.Name+'_'+aGrid.Name, 'col_'+IntToStr(i)+'_pos',  aGrid.Columns[i].Index);
    end;
  finally
    FreeAndNil(INI); // sempre libera o arquivo INI
  end;
end;
 {$endregion}
