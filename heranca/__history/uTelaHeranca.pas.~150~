{$REGION ' btn Pesquisar'}
procedure TForm1.btnPesquisarClick(Sender: TObject);
var
  I: Integer;
  TipoCampo: TFieldType;
  NomeCampo: string;
  WhereOrAnd: string;
  CondicaoSQL: string;
  SQLSemOrder: string;
  OrderByClause: string;
  PosOrder: Integer;
  ValorInt: Integer;
  Texto: string;
begin
  // 🔥 remove espaços
  Texto := Trim(mskPesquisar.Text);

  // cancela edição ativa
  if FDQListagem.State in [dsEdit, dsInsert] then
    FDQListagem.Cancel;

  // 🔐 PERMISSÃO
  if not TUsuarioLogado.TenhoAcesso(
    oUsuarioLogado.codigo,
    Self.Name + '_' + TBitBtn(Sender).Name,
    dtmPrincipal.dtmPrincipalDB) then
  begin
    MessageDlg('Usuário: ' + oUsuarioLogado.nome + ' não tem permissão',
      mtWarning, [mbOK], 0);
    Exit;
  end;

  // 🔎 SEM FILTRO
  if Texto = '' then
  begin
    FDQListagem.Close;
    FDQListagem.SQL.Text := SelectOriginal;
    FDQListagem.Open;
    Exit;
  end;

  NomeCampo := '';
  CondicaoSQL := '';

  // 🔥 REMOVE ORDER BY
  PosOrder := Pos('ORDER BY', UpperCase(SelectOriginal));

  if PosOrder > 0 then
  begin
    SQLSemOrder := Copy(SelectOriginal, 1, PosOrder - 1);
    OrderByClause := Copy(SelectOriginal, PosOrder, Length(SelectOriginal));
  end
  else
  begin
    SQLSemOrder := SelectOriginal;
    OrderByClause := '';
  end;

  // 🔥 DEFINE WHERE OU AND
  if Pos('where', LowerCase(SQLSemOrder)) > 0 then
    WhereOrAnd := ' AND '
  else
    WhereOrAnd := ' WHERE ';

  // 🔥 STATUS (texto fixo)
  if SameText(Texto, 'Ativo') or
     SameText(Texto, 'Inativo') or
     SameText(Texto, 'Bloqueado') or
     SameText(Texto, 'Atenção') or
     SameText(Texto, 'Prospecto') then
  begin
    CondicaoSQL := WhereOrAnd +
                   'UPPER(S.descricao) = ' +
                   QuotedStr(UpperCase(Texto));

    FDQListagem.Close;
    FDQListagem.SQL.Text := SQLSemOrder + CondicaoSQL + ' ' + OrderByClause;
    FDQListagem.Open;

    mskPesquisar.Clear;
    Exit;
  end;

  // 🔍 IDENTIFICA CAMPO
  for I := 0 to FDQListagem.FieldCount - 1 do
  begin
    if FDQListagem.Fields[I].FieldName = IndiceAtual then
    begin
      TipoCampo := FDQListagem.Fields[I].DataType;

      // 🔥 MAPEAMENTO MANUAL
      if IndiceAtual = 'clienteId' then
      begin
        NomeCampo := 'C.clienteId';
        TipoCampo := ftInteger;
      end
      else if IndiceAtual = 'nome' then
        NomeCampo := 'C.nome'
      else if IndiceAtual = 'endereco' then
        NomeCampo := 'C.endereco'
      else if IndiceAtual = 'cidade' then
        NomeCampo := 'C.cidade'
      else if IndiceAtual = 'bairro' then
        NomeCampo := 'C.bairro'
      else if IndiceAtual = 'estado' then
        NomeCampo := 'C.estado'
      else if IndiceAtual = 'cep' then
        NomeCampo := 'C.cep'
      else if IndiceAtual = 'telefone' then
        NomeCampo := 'C.telefone'
      else if IndiceAtual = 'email' then
        NomeCampo := 'C.email'
      else if IndiceAtual = 'statusDescricao' then
      begin
        NomeCampo := 'S.descricao';
        TipoCampo := ftString;
      end
      else if IndiceAtual = 'tipoPessoa' then
      begin
        NomeCampo := 'D.descricao';
        TipoCampo := ftString;
      end
      else if IndiceAtual = 'creditoCliente' then
      begin
        NomeCampo := 'ISNULL(SUM(CR.credito),0)';
        TipoCampo := ftFloat;
      end
      else
        NomeCampo := FDQListagem.Fields[I].FieldName;

      Break;
    end;
  end;

  // 🚨 segurança: campo não encontrado
  if NomeCampo = '' then
  begin
    ShowMessage('Campo inválido para pesquisa!');
    Exit;
  end;

  // 🔥 MONTA CONDIÇÃO
if (TipoCampo in [ftInteger, ftSmallint, ftAutoInc]) then
begin
  if IndiceAtual = 'clienteId' then
  begin
    if not TryStrToInt(Texto, I) then
    begin
      ShowMessage('Digite um ID válido!');
      Exit;
    end;

    CondicaoSQL := WhereOrAnd +
                   'C.clienteId = ' + IntToStr(I);
  end
  else
  begin
    CondicaoSQL := WhereOrAnd +
                   NomeCampo + ' = ' + Texto;
  end;
end
else if (TipoCampo in [ftString, ftWideString]) then
begin
  CondicaoSQL := WhereOrAnd +
                 'UPPER(' + NomeCampo + ') LIKE ' +
                 QuotedStr('%' + UpperCase(Texto) + '%');
end;

  // 🔥 EXECUTA
    FDQListagem.Close;
  FDQListagem.SQL.Clear;
  FDQListagem.SQL.Add(SQLSemOrder);
  FDQListagem.SQL.Add(CondicaoSQL);
  FDQListagem.SQL.Add(OrderByClause);



FDQListagem.Open;

  mskPesquisar.Clear;

end;
{$ENDREGION}

