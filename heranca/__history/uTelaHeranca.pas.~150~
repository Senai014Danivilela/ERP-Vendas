{$REGION ' VALIDAÇAO DE CPF E CNPJ  '}
// Valida CPF (11 dígitos) ou CNPJ (14 dígitos)
function TForm1.DocumentoValido(const S: string): Boolean;
var
  Num: string;
  i: Integer;

  // Função interna que calcula um dígito verificador
  function CalcularDigito(Base: string; Pesos: array of Integer): Integer;
  var
    i, Soma, Resto: Integer;
{$REGION 'SOMA DOS NUMEROS'}
  begin
    // Multiplica cada número pelo seu peso e soma tudo
    // Ex: 1x10 + 2x9 + 3x8... = Soma
    Soma := 0;
    for i := 1 to Length(Base) do
      Soma := Soma + StrToInt(Base[i]) * Pesos[i-1];

    // CPF usa (Soma * 10) mod 11
    if Length(Base) <= 9 then
    begin
      Result := (Soma * 10) mod 11;
      if Result = 10 then Result := 0;
    end
    // CNPJ usa 11 - (Soma mod 11)
    else
    begin
      Resto := Soma mod 11;
      if Resto < 2 then Result := 0
      else Result := 11 - Resto;
    end;
  end;  {$ENDREGION}
begin

 {$REGION 'CALCULO'}
  // PASSO 1: Remove tudo que não é número
  // Ex: "123.456.789-09" vira "12345678909"
  Num := '';
  for i := 1 to Length(S) do
    if S[i] in ['0'..'9'] then
      Num := Num + S[i];

  // PASSO 2: Verifica se tem 11 (CPF) ou 14 (CNPJ) dígitos
  if not (Length(Num) in [11, 14]) then
  begin
    Result := False;
    Exit;
  end;

  // PASSO 3: Rejeita sequências repetidas
  // Ex: 111.111.111-11 ou 00.000.000/0000-00
  if Num = StringOfChar(Num[1], Length(Num)) then
  begin
    Result := False;
    Exit;
  end;
         {$ENDREGION}

 {$REGION 'VALIDAÇAO'}
  // PASSO 4: Valida CPF
  // Verifica se os 2 últimos dígitos batem com o cálculo
  if Length(Num) = 11 then
    Result :=
      (CalcularDigito(Copy(Num,1,9),  [10,9,8,7,6,5,4,3,2])   = StrToInt(Num[10])) and
      (CalcularDigito(Copy(Num,1,10), [11,10,9,8,7,6,5,4,3,2]) = StrToInt(Num[11]))

  // PASSO 5: Valida CNPJ
  // Mesma lógica do CPF mas com pesos diferentes
  else
    Result :=
      (CalcularDigito(Copy(Num,1,12), [5,4,3,2,9,8,7,6,5,4,3,2])   = StrToInt(Num[13])) and
      (CalcularDigito(Copy(Num,1,13), [6,5,4,3,2,9,8,7,6,5,4,3,2]) = StrToInt(Num[14]));
    {$ENDREGION}
 end;

  {$endregion}

{$REGION ' Buscar CEP  '}
function TForm1.BuscarCEP(const CEP: string): TJSONObject;
var
  Http: THTTPClient;
  Resp: IHTTPResponse;
begin
  Http := THTTPClient.Create;
  try
    Resp := Http.Get('https://viacep.com.br/ws/' + CEP + '/json/');
    Result := TJSONObject.ParseJSONValue(Resp.ContentAsString) as TJSONObject;
  finally
    Http.Free;
  end;
end;
{$endregion}


