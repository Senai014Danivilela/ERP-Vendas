  object FDQVenda: TFDQuery
    Active = True
    Connection = dtmPrincipal.dtmPrincipalDB
    SQL.Strings = (
      'SELECT '
      '    V.vendaId,'
      '    V.clienteId,'
      '    C.nome,'
      '    V.dataVenda,'
      '    CAST(V.totalVenda AS NUMERIC(18,3)) AS TotalVenda,'
      '    ISNULL(SUM(CR.credito), 0) AS creditoCliente'
      ''
      'FROM VENDAS V'
      ''
      'INNER JOIN CLIENTES C '
      '    ON C.clienteId = V.clienteId'
      ''
      'LEFT JOIN CREDITO CR '
      '    ON CR.clienteId = V.clienteId'
      ''
      'WHERE V.vendaId = :vendaId'
      ''
      'GROUP BY'
      '    V.vendaId,'
      '    V.clienteId,'
      '    C.nome,'
      '    V.dataVenda,'
      '    V.totalVenda')
    Left = 152
    Top = 368
