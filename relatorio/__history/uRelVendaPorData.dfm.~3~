  object FDQVenda: TFDQuery
    Connection = dtmPrincipal.dtmPrincipalDB
    SQL.Strings = (
      'SELECT VENDAS.vendaId,'
      '       VENDAS.clienteID,'
      '       CLIENTES.nome,'
      '       VENDAS.dataVenda,'
      '       CAST( VENDAS.totalVenda AS FLOAT) AS totalVenda'
      'FROM VENDAS'
      '    INNER JOIN CLIENTES ON CLIENTES.clienteID = VENDAS.clienteID'
      'WHERE VENDAS.dataVenda BETWEEN :DataInicio AND :DataFim'
      'ORDER BY VENDAS.dataVenda, VENDAS.clienteID')
    Left = 488
    Top = 336
    ParamData = <
      item
        Name = 'DATAINICIO'
        DataType = ftDate
        ParamType = ptInput
        Value = '01/03/2026'
      end
      item
        Name = 'DATAFIM'
        DataType = ftDate
        ParamType = ptInput
        Value = '31/03/2026'
      end>
