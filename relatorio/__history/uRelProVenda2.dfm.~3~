  object FDQVenda: TFDQuery
    Connection = dtmPrincipal.dtmPrincipalDB
    SQL.Strings = (
      'SELECT '
      '    V.vendaId,'
      '    V.clienteID,'
      '    C.nome,'
      '    V.dataVenda,'
      '    CAST(V.totalVenda AS FLOAT) AS totalVenda,'
      '    ISNULL(SUM(CR.credito), 0) AS creditoCliente'
      ''
      'FROM VENDAS V'
      ''
      'INNER JOIN CLIENTES C '
      '    ON C.clienteID = V.clienteID'
      ''
      'LEFT JOIN CREDITO CR '
      '    ON CR.clienteId = V.clienteId'
      ''
      'WHERE V.dataVenda BETWEEN :DataInicio AND :DataFim'
      ''
      'GROUP BY'
      '    V.vendaId,'
      '    V.clienteID,'
      '    C.nome,'
      '    V.dataVenda,'
      '    V.totalVenda'
      ''
      'ORDER BY '
      '    V.dataVenda,'
      '    V.clienteID')
    Left = 152
    Top = 368
    ParamData = <
      item
        Name = 'DATAINICIO'
        DataType = ftDate
        ParamType = ptInput
        Value = 46082d
      end
      item
        Name = 'DATAFIM'
        DataType = ftDate
        ParamType = ptInput
        Value = 46112d
      end>
