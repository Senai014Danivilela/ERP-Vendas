end;



procedure TfrmCadCliente.edtCEPExit(Sender: TObject);
var
  JSON: TJSONObject;
  cep: string;
begin
  cep := SomenteNumeros  (edtCEP.Text);

  JSON := BuscarCEP(cep);
  try
    if Assigned(JSON) then
    begin
      edtEndereco.Text := JSON.GetValue<string>('logradouro');
      edtCidade.Text := JSON.GetValue<string>('localidade');
       edtUF.Text := JSON.GetValue<string>('uf');
        edtBairro.Text := JSON.GetValue<string>('bairro');
    end;
  finally
    JSON.Free;
  end;
end;

procedure TfrmCadCliente.edtCpfCnpjChange(Sender: TObject);
var
  s: string;
begin
  s := SomenteNumeros(edtCpfCnpj.Text);
                        {$REGION 'Explicaçao '}
                   {   CPF
                   Digita: 36291154897
     Vira automaticamente: 362.911.548-97

                     CNPJ
                   Digita: 11111111000111
                     Vira: 11.111.111/0001-11
                           }
                               {$endregion}
 {$REGION 'CPF '}
  if lkpPessoa.KeyValue = 1 then
  begin
    if Length(s) > 11 then s := Copy(s, 1, 11);

    if Length(s) > 9 then
      edtCpfCnpj.Text := Copy(s,1,3)+'.'+Copy(s,4,3)+'.'+Copy(s,7,3)+'-'+Copy(s,10,2)
    else if Length(s) > 6 then
      edtCpfCnpj.Text := Copy(s,1,3)+'.'+Copy(s,4,3)+'.'+Copy(s,7,3)
    else if Length(s) > 3 then
      edtCpfCnpj.Text := Copy(s,1,3)+'.'+Copy(s,4,3)
    else
      edtCpfCnpj.Text := s;
  end
 {$endregion}

 {$REGION 'CNPJ'}
  else if lkpPessoa.KeyValue = 2 then
  begin
    if Length(s) > 14 then s := Copy(s, 1, 14);

    if Length(s) > 12 then
      edtCpfCnpj.Text := Copy(s,1,2)+'.'+Copy(s,3,3)+'.'+Copy(s,6,3)+'/'+Copy(s,9,4)+'-'+Copy(s,13,2)
    else if Length(s) > 8 then
      edtCpfCnpj.Text := Copy(s,1,2)+'.'+Copy(s,3,3)+'.'+Copy(s,6,3)+'/'+Copy(s,9,4)
    else if Length(s) > 5 then
      edtCpfCnpj.Text := Copy(s,1,2)+'.'+Copy(s,3,3)+'.'+Copy(s,6,3)
    else if Length(s) > 2 then
      edtCpfCnpj.Text := Copy(s,1,2)+'.'+Copy(s,3,3)
    else
      edtCpfCnpj.Text := s;
  end;
{$endregion}

  edtCpfCnpj.SelStart := Length(edtCpfCnpj.Text); // cursor no final
end;

procedure TfrmCadCliente.edtTelefoneKeyUp(Sender: TObject; var Key: Word; Shift: TShiftState);
var
num: string;
begin
 num := SomenteNumeros(edtTelefone.Text);

 edtTelefone.EditMask := '';

  if (Copy(num,1,1)='0')and (Length(num) >= 10)  then
 edtTelefone.EditMask := '0000 000 0000;1;_'
 else if Length(num) = 11 then
 edtTelefone.EditMask := '(00)00000\-0000;1;_'
 else if Length(num) = 10 then
 edtTelefone.EditMask := '(00)0000\-0000;1;_';

 edtTelefone.SelStart := Length(edtTelefone.Text);
end;

procedure TfrmCadCliente.lblCpfCnpjClick(Sender: TObject);
begin
case lkpPessoa.KeyValue of
    1: lblCpfCnpj.Caption := 'CPF';
    2: lblCpfCnpj.Caption := 'CNPJ';
  end;

  inherited;

end;

procedure TfrmCadCliente.lkpPessoaCloseUp(Sender: TObject);
begin
 if VarIsNull(lkpPessoa.KeyValue) then Exit;

  case lkpPessoa.KeyValue of
    1: lblCpfCnpj.Caption := 'CPF';
    2: lblCpfCnpj.Caption := 'CNPJ';
  end;

  edtCpfCnpj.Clear; // limpa ao trocar tipo
  inherited;

end;

procedure TfrmCadCliente.FormClose(Sender: TObject; var Action: TCloseAction);
