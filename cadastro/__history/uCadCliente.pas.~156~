begin
  inherited;
  FDQListagem.Connection:=dtmPrincipal.dtmPrincipalDB;
  oCliente := TCliente.Create(dtmPrincipal.dtmPrincipalDB);
  grdListagem.OnDrawColumnCell := grdListagemDrawColumnCell;
  oCredito := TCredito.Create(dtmPrincipal.dtmPrincipalDB);

      FDQListagem.SQL.Add('SELECT C.clienteId, C.nome, C.cep, C.telefone, C.email ');
      FDQListagem.SQL.Add('  FROM CLIENTES C ');
      FDQListagem.SQL.Add('  LEFT JOIN CREDITO CR ON CR.clienteId = C.clienteID ');

  IndiceAtual := 'nome'
end;

procedure TfrmCadCliente.FormDestroy(Sender: TObject);
