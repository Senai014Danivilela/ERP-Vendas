end;

function TfrmCadCliente.Gravar(EstadoDoCadastro: TEstadoCadastro): Boolean;
var
  diferenca: Double;
begin
  // ?? ID
  if edtClienteId.Text <> '' then
    oCliente.codigo := StrToInt(edtClienteId.Text)
  else
    oCliente.codigo := 0;

  // ?? DADOS
  oCliente.nome           := edtNome.Text;
  oCliente.endereco       := edtEndereco.Text;
  oCliente.cidade         := edtCidade.Text;
  oCliente.bairro         := edtBairro.Text;
  oCliente.cep            := edtCEP.Text;
  oCliente.telefone       := edtTelefone.Text;
  oCliente.email          := edtEmail.Text;
  oCliente.dataNascimento := edtDataNascimento.Date;
  oCliente.statusId       := lkpStatus.KeyValue;
  oCliente.documentoId    := lkpPessoa.KeyValue;
  oCliente.documento      := edtCpfCnpj.Text;

  // ? NĂO USAR MAIS
  // oCliente.credito := edtCredito.Value;

  // ?? INSERT OU UPDATE
  if EstadoDoCadastro = ecInserir then
    Result := oCliente.Inserir
  else
    Result := oCliente.Atualizar;

  // ?? CONTROLE DE CRÉDITO (ÚNICO LUGAR)
  if Result then
  begin
    // ?? NOVO CLIENTE
    if EstadoDoCadastro = ecInserir then
    begin
      if edtCredito.Value > 0 then
        oCredito.AdicionarCredito(oCliente.codigo, edtCredito.Value);
    end

    // ?? ALTERAÇĂO
    else
    begin
      diferenca := edtCredito.Value - CreditoOriginal;

      if diferenca > 0 then
        oCredito.AdicionarCredito(oCliente.codigo, diferenca)

      else if diferenca < 0 then
        oCredito.DescontarCredito(oCliente.codigo, Abs(diferenca));
    end;

    // ?? STATUS
    oCliente.AtualizarStatus;
  end;
end;




procedure TfrmCadCliente.grdListagemDrawColumnCell(Sender: TObject;
  const Rect: TRect; DataCol: Integer; Column: TColumn;
  State: TGridDrawState);
var
  imgIndex: Integer;
  x, y: Integer;
begin
  // chama zebra + desenho padrăo
  inherited;

  if Assigned(Column.Field) and (Column.Field.FieldName = 'statusId') then
  begin
    // ?? LIMPA o que o pai desenhou (isso resolve!)
    grdListagem.Canvas.FillRect(Rect);

    case Column.Field.AsInteger of
      1: imgIndex := 0;
      2: imgIndex := 1;
      3: imgIndex := 2;
      4: imgIndex := 3;
      5: imgIndex := 4;
    else
      Exit;
    end;

    x := Rect.Left + (Rect.Width div 2) - (ImageListStatus.Width div 2);
    y := Rect.Top + (Rect.Height div 2) - (ImageListStatus.Height div 2);

    ImageListStatus.Draw(grdListagem.Canvas, x, y, imgIndex);
  end;
end;




