  inherited FDQListagem: TFDQuery
    AfterScroll = FDQListagemAfterScroll
    SQL.Strings = (
      'SELECT '
      '    C.clienteId,'
      '    C.nome,'
      '    C.endereco,'
      '    C.cidade,'
      '    C.bairro,'
      '    C.estado,'
      '    C.cep,'
      '    C.telefone,'
      '    C.email,'
      '    C.dataNascimento,'
      '    C.statusId,'
      '    S.descricao AS statusDescricao,'
      '    D.descricao AS tipoPessoa,'
      '    C.documento,'
      ''
      '    ISNULL(SUM(CR.credito), 0) AS creditoCliente'
      ''
      'FROM CLIENTES C'
      ''
      'LEFT JOIN STATUSCLIENTES S'
      '    ON C.statusId = S.statusId'
      ''
      'LEFT JOIN DOCUMENTOS D'
      '    ON C.documentoId = D.documentoId'
      ''
      'LEFT JOIN CREDITO CR'
      '    ON CR.clienteId = C.clienteId'
      ''
      'GROUP BY '
      '    C.clienteId,'
      '    C.nome,'
      '    C.endereco,'
      '    C.cidade,'
      '    C.bairro,'
      '    C.estado,'
      '    C.cep,'
      '    C.telefone,'
      '    C.email,'
      '    C.dataNascimento,'
      '    C.statusId,'
      '    S.descricao,'
      '    D.descricao,'
      '    C.documento')
    Left = 20
    Top = 320
    object FDQListagemclienteId: TFDAutoIncField
      DisplayLabel = 'C'#243'digo'
      FieldName = 'clienteId'
      Origin = 'clienteId'
      ProviderFlags = [pfInWhere, pfInKey]
      ReadOnly = True
    end
