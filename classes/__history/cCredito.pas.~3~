unit cCredito;

interface

uses FireDAC.Comp.Client, System.SysUtils;

type
  TCredito = class
  private
    FConexao: TFDConnection; // conex„o com banco
  public
    constructor Create(AConexao: TFDConnection);

    function AdicionarCredito(clienteId: Integer; valor: Double): Boolean;
    function DescontarCredito(clienteId: Integer; valor: Double): Boolean;
    function ObterSaldo(clienteId: Integer): Double;
  end;

implementation

constructor TCredito.Create(AConexao: TFDConnection);
begin
  FConexao := AConexao; // recebe a conex„o do sistema
end;

 function TCredito.AdicionarCredito(clienteId: Integer; valor: Double): Boolean;
var FDQ: TFDQuery;
begin
  Result := False;

  FDQ := TFDQuery.Create(nil);
  try
    FDQ.Connection := FConexao;

    // insere crÈdito positivo
    FDQ.SQL.Text :=
      'INSERT INTO CREDITO (clienteId, credito, tipo) '+
      'VALUES (:id, :valor, ''ENTRADA'')';

    FDQ.ParamByName('id').AsInteger := clienteId;
    FDQ.ParamByName('valor').AsFloat := valor;

    FDQ.ExecSQL; // executa
    Result := True;
  finally
    FDQ.Free;
  end;
end;

 function TCredito.DescontarCredito(clienteId: Integer; valor: Double): Boolean;
var FDQ: TFDQuery;
begin
  Result := False;

  FDQ := TFDQuery.Create(nil);
  try
    FDQ.Connection := FConexao;

    // insere valor NEGATIVO (dÌvida)
    FDQ.SQL.Text :=
      'INSERT INTO CREDITO (clienteId, credito, tipo) '+
      'VALUES (:id, :valor, ''SAIDA'')';

    FDQ.ParamByName('id').AsInteger := clienteId;
    FDQ.ParamByName('valor').AsFloat := -valor; // negativo

    FDQ.ExecSQL;
    Result := True;
  finally
    FDQ.Free;
  end;
end;

function TCredito.ObterSaldo(clienteId: Integer): Double;
var FDQ: TFDQuery;
begin
  FDQ := TFDQuery.Create(nil);
  try
    FDQ.Connection := FConexao;

    FDQ.SQL.Text :=
      'SELECT ISNULL(SUM(credito),0) FROM CREDITO WHERE clienteId = :id';

    FDQ.ParamByName('id').AsInteger := clienteId;
    FDQ.Open;

    Result := FDQ.Fields[0].AsFloat;
  finally
    FDQ.Free;
  end;
end;



end.
