  object FDQValorVendaPorCliente: TFDQuery
    Active = True
    Connection = dtmPrincipal.dtmPrincipalDB
    SQL.Strings = (
      
        'SELECT CONVERT(VARCHAR,VENDAS.clienteID) +'#39' _ '#39'+CLIENTES.nome AS' +
        ' Label,'
      'SUM(VENDAS.totalVenda) AS Value'
      'FROM VENDAS'
      
        '     INNER JOIN CLIENTES ON CLIENTES.clienteID = VENDAS.clienteI' +
        'D'
      
        'WHERE VENDAS.dataVenda BETWEEN CONVERT(DATE,GETDATE()-7)AND CONV' +
        'ERT(DATE,GETDATE())'
      'GROUP BY VENDAS.clienteID,CLIENTES.nome'
      '')
    Left = 63
    Top = 94
    object FDQValorVendaPorClienteLabel: TStringField
      FieldName = 'Label'
      Origin = 'Label'
      ReadOnly = True
      Size = 93
    end
